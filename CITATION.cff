    given-names: Ahram
    email: ahramahn82@gmail.com
version: 0.3.0
date-released: "2026-05-02"
license: MIT
repository-code: "https://github.com/Ahram-Ahn/mtRNAFeat"
url: "https://github.com/Ahram-Ahn/mtRNAFeat"
keywords:
  - mitochondrial RNA
  - DMS-MaPseq
  - secondary structure
  - ViennaRNA
  - RNAplfold
  - thermodynamics
  - bioinformatics
